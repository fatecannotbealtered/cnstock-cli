{
  "name": "@fateforge/cnstock-cli",
  "version": "1.1.6",
  "description": "Market data lookup CLI for AI Agents - quotes, K-line bars, intraday minutes, stock search, sectors, and market breadth for A/HK/US symbols",
  "keywords": [
    "cnstock",
    "finance",
    "stock",
    "cli",
    "ai-agent",
    "a-share",
    "hk-stock",
    "us-stock"
  ],
  "author": "Sean Guo",
  "homepage": "https://github.com/fatecannotbealtered/cnstock-cli#readme",
  "bugs": {
    "url": "https://github.com/fatecannotbealtered/cnstock-cli/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fatecannotbealtered/cnstock-cli.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "cnstock-cli": "scripts/run.js"
  },
  "optionalDependencies": {
    "@fateforge/cnstock-cli-darwin-arm64": "1.1.6",
    "@fateforge/cnstock-cli-darwin-x64": "1.1.6",
    "@fateforge/cnstock-cli-linux-arm64": "1.1.6",
    "@fateforge/cnstock-cli-linux-x64": "1.1.6",
    "@fateforge/cnstock-cli-win32-arm64": "1.1.6",
    "@fateforge/cnstock-cli-win32-x64": "1.1.6"
  },
  "files": [
    "scripts/run.js",
    "skills/",
    "README.md",
    "README_zh.md",
    "*_zh.md",
    "LICENSE",
    "NOTICE.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "AGENTS.md",
    ".agent/",
    "docs/"
  ],
  "engines": {
    "node": ">=16"
  }
}
